@model IEnumerable<WebNauAn.Models.Recipe>
@{
    ViewData["Title"] = "Trang Chủ Món Ăn";
    var categories = ViewBag.Categories as List<WebNauAn.Models.Category>;
    var topLiked = ViewBag.TopLiked as List<WebNauAn.Models.Recipe>;
    var topCommented = ViewBag.TopCommented as List<WebNauAn.Models.Recipe>;

    var currentUser = Context.Session.GetString("Username");
    var currentRole = Context.Session.GetString("Role");
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card mb-4 shadow-sm border-success">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">📂 Danh Mục Món Ăn</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a href="/Recipe/Index" class="list-group-item list-group-item-action @(ViewBag.CategoryId == null ? "active bg-success border-success" : "")">✨ Tất cả món ăn</a>
                    @if (categories != null)
                    {
                        var groupedCategories = categories.GroupBy(c => c.MucCha);
                        int index = 0;
                        foreach (var group in groupedCategories)
                        {
                            index++;
                            var collapseId = "collapseCat_" + index;
                            bool isCurrentGroup = group.Any(c => c.Id == ViewBag.CategoryId);
                            <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center fw-bold @(isCurrentGroup ? "text-success bg-light" : "")" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                <span>📁 @group.Key</span>
                                <small class="text-muted">▼</small>
                            </button>
                            <div class="collapse @(isCurrentGroup ? "show" : "")" id="@collapseId">
                                <div class="list-group list-group-flush ps-3 border-start border-success border-3">
                                    @foreach (var cat in group)
                                    {
                                        <a href="/Recipe/Index?categoryId=@cat.Id" class="list-group-item list-group-item-action py-2 small @(ViewBag.CategoryId == cat.Id ? "active bg-success border-success text-white fw-bold" : "")">🔹 @cat.MucCon</a>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="card mb-4 shadow-sm border-primary">
                <div class="card-header bg-primary text-white"><h5 class="mb-0">👍 Top Món Nhiều Like Nhất</h5></div>
                <div class="list-group list-group-flush">
                    @if (topLiked != null && topLiked.Any())
                    {
                        int rank = 1; foreach (var item in topLiked)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center"><div><strong class="text-danger">#@rank</strong> @item.TenMon</div><span class="badge bg-primary rounded-pill">👍 @item.LuotLike</span></div>
                            rank++;
                        }
                    }
                    else
                    {

                        <div class="list-group-item text-muted text-center py-3">Chưa có dữ liệu</div>
                    }
                </div>
            </div>

            <div class="card mb-4 shadow-sm border-warning">
                <div class="card-header bg-warning text-dark font-weight-bold"><h5 class="mb-0">💬 Top Món Tương Tác Khủng</h5></div>
                <div class="list-group list-group-flush">
                    @if (topCommented != null && topCommented.Any())
                    {
                        int rank = 1; foreach (var item in topCommented)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center"><div><strong class="text-success">#@rank</strong> @item.TenMon</div><span class="badge bg-warning text-dark rounded-pill">💬 @item.Comments.Count</span></div>
                            rank++;
                        }
                    }
                    else
                    {

                        <div class="list-group-item text-muted text-center py-3">Chưa có dữ liệu</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card p-3 mb-4 shadow-sm bg-light border">
                <form action="/Recipe/Index" method="get">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label small text-secondary">🔍 Tìm theo tên món ăn:</label>
                            <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Nhập tên món ăn..." />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small text-secondary">🥑 Có sẵn nguyên liệu gì?</label>
                            <input type="text" name="ingredientsString" value="@ViewBag.IngredientsString" class="form-control" placeholder="Ví dụ: thịt heo, trứng..." />
                        </div>
                    </div>
                    <div class="text-end mt-3">
                        <a href="/Recipe/Index" class="btn btn-outline-secondary btn-sm me-2">Xóa bộ lọc</a>
                        <button type="submit" class="btn btn-success btn-sm px-4">Áp dụng tìm kiếm</button>
                    </div>
                </form>
            </div>

            <h4 class="mb-3 text-success font-weight-bold border-bottom pb-2">🍳 Danh Sách Công Thức Nấu Ăn</h4>

            <div class="row row-cols-1 row-cols-md-2 g-3">
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border position-relative">

                            @if (currentRole == "Admin" || (!string.IsNullOrEmpty(currentUser) && item.Username == currentUser))
                            {
                                <div class="position-absolute top-0 end-0 m-2" style="z-index: 10;">
                                    <a href="/Recipe/Edit/@item.Id" class="btn btn-sm btn-warning fw-bold text-dark shadow">✏️ Sửa</a>
                                </div>
                            }

                            <img src="@item.HinhanhUrl" class="card-img-top" alt="@item.TenMon" style="height: 180px; object-fit: cover;" />

                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-center mb-1">
                                    <h5 class="card-title text-success font-weight-bold mb-0 me-2">@item.TenMon</h5>
                                    @if (currentRole == "Admin")
                                    {
                                        if (item.IsApproved)
                                        {
                                            <span class="badge bg-success" style="font-size:0.65rem;">Đã duyệt</span>
                                        }
                                        else
                                        {

                                            <span class="badge bg-danger" style="font-size:0.65rem;">Chờ duyệt</span>
                                        }
                                    }
                                </div>

                                <p class="badge bg-secondary mb-2 align-self-start" style="font-size: 0.75rem;">🏷️ @item.Category?.MucCha → @item.Category?.MucCon</p>
                                <p class="text-muted small mb-0" style="font-size: 0.75rem;">👤 Người đăng: <b>@item.Username</b></p>
                                <hr class="my-1">
                                <p class="card-text text-muted small mb-1"><strong>🛒 Nguyên liệu:</strong> @(item.NguyenLieu.Length > 60 ? item.NguyenLieu.Substring(0, 60) + "..." : item.NguyenLieu)</p>
                                <p class="card-text text-muted small mb-3"><strong>📝 Cách làm:</strong> @(item.CongThuc.Length > 60 ? item.CongThuc.Substring(0, 60) + "..." : item.CongThuc)</p>

                                <div class="mt-auto border-top pt-2">
                                    <div class="d-flex justify-content-between mb-2" style="font-size: 0.8rem;">
                                        <span class="text-primary">👍 <b>@item.LuotLike</b> lượt thích</span>
                                        <span class="text-secondary">💬 <b>@item.Comments.Count</b> bình luận</span>
                                    </div>

                                    <div class="d-flex justify-content-between mb-2">
                                        @if (!string.IsNullOrEmpty(currentUser))
                                        {
                                            <a href="/Recipe/Like/@item.Id" class="btn btn-light btn-sm text-primary border col-5 py-0">👍 Thích</a>
                                            <a href="/Recipe/SaveRecipe/@item.Id" class="btn btn-light btn-sm text-warning border col-6 py-0">⭐ Lưu món</a>
                                        }
                                        else
                                        {
                                            <button onclick="alert('Bạn hãy đăng nhập để có thể sử dụng tính năng này');" class="btn btn-light btn-sm text-primary border col-5 py-0">👍 Thích</button>
                                            <button onclick="alert('Bạn hãy đăng nhập để có thể sử dụng tính năng này');" class="btn btn-light btn-sm text-warning border col-6 py-0">⭐ Lưu món</button>
                                        }
                                    </div>

                                    <div class="bg-light p-2 rounded mb-2 border" style="max-height: 90px; overflow-y: auto; font-size: 0.8rem;">
                                        @if (item.Comments.Any())
                                        {
                                            foreach (var cmt in item.Comments)
                                            {
                                                <div class="mb-1 border-bottom pb-1"><span class="@(cmt.Role == "Admin" ? "text-danger fw-bold" : "text-success")">@cmt.Username</span>: @cmt.NoiDung</div>
                                            }
                                        }
                                        else
                                        {

                                            <span class="text-muted d-block text-center small">Chưa có thảo luận nào.</span>
                                        }
                                    </div>

                                    @if (!string.IsNullOrEmpty(currentUser))
                                    {
                                        <form action="/Recipe/Comment" method="post">
                                            <input type="hidden" name="recipeId" value="@item.Id" />
                                            <div class="input-group input-group-sm">
                                                <input type="text" name="noiDung" class="form-control" placeholder="Bình luận món ăn..." required />
                                                <button class="btn btn-success text-white" type="submit">Gửi</button>
                                            </div>
                                        </form>
                                    }
                                    else
                                    {
                                        <div class="input-group input-group-sm" onclick="alert('Bạn hãy đăng nhập để có thể sử dụng tính năng này');">
                                            <input type="text" class="form-control" placeholder="Đăng nhập để bình luận..." disabled />
                                            <button class="btn btn-success text-white" disabled>Gửi</button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>