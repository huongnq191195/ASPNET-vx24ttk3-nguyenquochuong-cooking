@model IEnumerable<WebNauAn.Models.Recipe>

<h2>Danh Sách Công Thức Món Ăn (Đã Duyệt)</h2>
<a href="/Recipe/Create" class="btn btn-primary">Đăng công thức mới</a>
<hr />

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4">
            <div class="card" style="width: 18rem; margin-bottom: 20px;">
                <img src="@item.HinhanhUrl" class="card-img-top" alt="Ảnh món ăn">
                <div class="card-body">
                    <h5 class="card-title">@item.TenMon</h5>
                    <p class="card-text">@item.CongThuc</p>
                    <span class="badge bg-success">@item.Category?.TenQuocGia - @item.Category?.LoaiMon</span>

                    <div class="border-top pt-2 mt-2">
                        <button class="btn btn-light btn-sm text-primary" onclick="let count = this.querySelector('.like-count'); count.innerText = parseInt(count.innerText) + 1;">
                            👍 Like (<span class="like-count">0</span>)
                        </button>

                        <a href="https://www.facebook.com/sharer/sharer.php?u=https://google.com" target="_blank" class="btn btn-light btn-sm text-info">
                            🌐 Share FB
                        </a>
                        <a href="https://chat.zalo.me/" target="_blank" class="btn btn-light btn-sm text-success">
                            💬 Share Zalo
                        </a>

                        <div class="mt-2">
                            <input type="text" class="form-control form-control-sm" placeholder="Viết bình luận của bạn..."
                                   onkeypress="if(event.key === 'Enter' && this.value.trim() !== '') {
                            let p=document.createElement('p');
                            p.innerHTML='<b>Bạn:</b> ' + this.value;
                            p.className='small text-muted mb-1' ;
                            this.parentElement.querySelector('.box-cmt').appendChild(p);
                            this.value='' ;
                            }" />
                            <div class="box-cmt mt-2"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>