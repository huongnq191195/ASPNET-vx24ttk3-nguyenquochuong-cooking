@model IEnumerable<WebNauAn.Models.Recipe>

<div class="container mt-4">
    <div class="bg-white p-4 rounded shadow-sm border-start border-warning border-4 mb-4">
        <h2 class="text-warning m-0 font-weight-bold">⭐ Bộ Sưu Tập Công Thức Đã Lưu Của Bạn</h2>
        <p class="text-muted mb-0 small">Nơi lưu giữ các món ngon ruột của riêng bạn, tài khoản khác sẽ không thể nhìn thấy.</p>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden">
                        <a asp-action="Details" asp-route-id="@item.Id">
                            <img src="@item.HinhanhUrl" class="card-img-top" style="height: 180px; object-fit: cover;" alt="Ảnh món ăn" />
                        </a>
                        <div class="card-body d-flex flex-column">
                            <span class="badge bg-secondary mb-2 align-self-start">@item.Category?.MucCha - @item.Category?.MucCon</span>
                            <h5 class="card-title font-weight-bold text-success">@item.TenMon</h5>
                            <p class="card-text text-muted text-truncate">@item.CongThuc</p>
                            <div class="mt-auto pt-2">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-warning text-dark btn-sm w-100 font-weight-bold">Vào nấu ngay →</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center my-5 bg-white p-5 rounded shadow-sm">
                <p class="fs-4 text-muted">Kho lưu trữ của bạn đang trống trống trơn. Hãy quay lại trang chủ và bấm "Lưu món" nhé!</p>
                <a href="/Recipe/Index" class="btn btn-success mt-2">Quay lại tìm món ngon</a>
            </div>
        }
    </div>
</div>