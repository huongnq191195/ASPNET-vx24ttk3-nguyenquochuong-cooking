@model WebNauAn.Models.Recipe

<div class="container mt-5">
    <div class="card shadow border-0 rounded-3 overflow-hidden">
        <div class="card-body p-5">
            <h1 class="text-success mb-4 font-weight-bold">@Model.TenMon</h1>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <img src="@Model.HinhanhUrl" class="img-fluid rounded shadow-sm w-100" style="max-height: 400px; object-fit: cover;" alt="Ảnh món ăn" />
                </div>
                <div class="col-md-6">
                    <div class="p-4 bg-light rounded-3 h-100">
                        <h5 class="text-secondary font-weight-bold">📌 Thuộc phân loại:</h5>
                        <p class="badge bg-success p-2 fs-6">@Model.Category?.MucCha → @Model.Category?.MucCon</p>

                        <div class="mt-4">
                            <h5 class="text-primary font-weight-bold">🛒 Nguyên liệu chuẩn bị:</h5>
                            <div class="p-2 bg-white rounded border small" style="white-space: pre-line;">
                                @Model.NguyenLieu
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-5">
                <h3 class="text-success border-bottom pb-2">🍳 Các bước thực hiện chi tiết:</h3>
                <div class="mt-3 p-3 text-dark fs-5" style="white-space: pre-line; line-height: 1.8;">
                    @Model.CongThuc
                </div>
            </div>

        </div>
        <div class="card-footer bg-white p-4 border-top d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-outline-secondary px-4">← Quay lại trang chủ</a>
            <a href="/Recipe/SaveRecipe/@Model.Id" class="btn btn-warning font-weight-bold text-dark">⭐ Lưu món ăn này</a>
        </div>
    </div>
</div>