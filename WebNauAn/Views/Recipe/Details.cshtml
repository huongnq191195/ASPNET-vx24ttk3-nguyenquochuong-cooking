@model WebNauAn.Models.Recipe
@using Microsoft.AspNetCore.Http

@{
    var currentRole = Context.Session.GetString("Role");
    var currentUser = Context.Session.GetString("Username");
}

<div class="container mt-5">
    <div class="card shadow border-0 rounded-3 overflow-hidden">
        <div class="card-body p-5">
            <h1 class="text-success mb-4 font-weight-bold">
                @Model.TenMon
                @if (!Model.IsApproved)
                {
                    <span class="badge bg-danger fs-6 align-middle ms-2">⏳ Đang chờ duyệt</span>
                }
            </h1>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <img src="@Model.HinhanhUrl" class="img-fluid rounded shadow-sm w-100 hover-effect" style="max-height: 400px; object-fit: cover;" alt="Ảnh món ăn" />
                </div>
                <div class="col-md-6">
                    <div class="p-4 bg-light rounded-3 h-100 shadow-sm border">
                        <h5 class="text-secondary font-weight-bold">📌 Thuộc phân loại:</h5>
                        <p class="badge bg-success p-2 fs-6 hover-effect">@Model.Category?.MucCha → @Model.Category?.MucCon</p>

                        <div class="mt-4">
                            <h5 class="text-primary font-weight-bold">🛒 Nguyên liệu chuẩn bị:</h5>
                            <div class="p-2 bg-white rounded border small" style="white-space: pre-line;">@Model.NguyenLieu</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-5">
                <h3 class="text-success border-bottom pb-2">🍳 Các bước thực hiện chi tiết:</h3>
                <div class="mt-3 p-3 text-dark fs-5" style="white-space: pre-line; line-height: 1.8;">@Model.CongThuc</div>
            </div>

            <div class="mt-5 border-top pt-4">
                <h3 class="text-secondary mb-3">💬 Bình luận & Thảo luận (@Model.Comments.Count)</h3>
                
                <div class="bg-light p-3 rounded mb-4" style="max-height: 300px; overflow-y: auto;">
                    @if (Model.Comments.Any())
                    {
                        @foreach (var cmt in Model.Comments.OrderByDescending(c => c.NgayDang))
                        {
                            <div class="mb-2 border-bottom pb-1">
                                <span class="@(cmt.Role == "Admin" ? "text-danger fw-bold" : "text-success")">
                                    @(cmt.Role == "Admin" ? "👑 " : "👤 ") @cmt.Username
                                </span>
                                <small class="text-muted">(@cmt.NgayDang.ToString("dd/MM/yyyy HH:mm"))</small>
                                <p class="mb-0">@cmt.NoiDung</p>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">Chưa có bình luận nào cho món này.</p>
                    }
                </div>

                @if (!string.IsNullOrEmpty(currentUser))
                {
                    <form action="/Recipe/Comment" method="post" class="mt-3">
                        <input type="hidden" name="recipeId" value="@Model.Id" />
                        <div class="input-group">
                            <input type="text" name="noiDung" class="form-control" placeholder="Viết bình luận của bạn tại đây..." required />
                            <button class="btn btn-success" type="submit">Gửi bình luận</button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="alert alert-warning">
                        Vui lòng <a href="/Account/Login" class="alert-link">Đăng nhập</a> để tham gia thảo luận.
                    </div>
                }
            </div>
            @if (currentRole == "Admin" && Model.IsSuaDoi)
            {
                <div class="alert alert-danger mt-5 shadow-sm border-danger">
                    <h4 class="text-danger fw-bold mb-3">⚠️ BÀI VIẾT NÀY ĐÃ ĐƯỢC NGƯỜI DÙNG CHỈNH SỬA</h4>
                    <p class="mb-2 text-dark">Dưới đây là <b>nội dung CŨ</b> trước khi sửa để Admin so sánh đối chiếu:</p>
                    <hr class="border-danger" />
                    <p><strong>📌 Tên món cũ:</strong> <del class="text-muted">@Model.TenMonCu</del></p>
                    <p><strong>🛒 Nguyên liệu cũ:</strong></p>
                    <div class="p-2 bg-white rounded border small text-muted" style="white-space: pre-line;"><del>@Model.NguyenLieuCu</del></div>
                    <p class="mt-2"><strong>🍳 Cách làm cũ:</strong></p>
                    <div class="p-2 bg-white rounded border small text-muted" style="white-space: pre-line;"><del>@Model.CongThucCu</del></div>
                </div>
            }
        </div>

        <div class="card-footer bg-light p-4 border-top d-flex flex-wrap justify-content-between align-items-center">
            <a asp-action="Index" class="btn btn-outline-secondary px-4 hover-effect fw-bold mb-2">← Quay lại</a>

            <div class="mb-2">
                @if (currentRole == "Admin")
                {
                    if (!Model.IsApproved)
                    {
                        <a href="/Recipe/Approve/@Model.Id" class="btn btn-success fw-bold me-2 hover-effect shadow-sm">✔ Duyệt bài này</a>
                    }
                    <a href="/Recipe/Edit/@Model.Id" class="btn btn-warning fw-bold text-dark me-2 hover-effect shadow-sm">✏️ Sửa bài</a>
                    <a href="/Recipe/Delete/@Model.Id" onclick="return confirm('Hành động này không thể hoàn tác. Bạn chắc chắn muốn xóa bài này?');" class="btn btn-danger fw-bold hover-effect shadow-sm">❌ Xóa bài</a>
                }
                else if (currentUser == Model.Username)
                {
                    <a href="/Recipe/Edit/@Model.Id" class="btn btn-warning fw-bold text-dark hover-effect shadow-sm">✏️ Sửa bài viết của tôi</a>
                }

                @if (!string.IsNullOrEmpty(currentUser))
                {
                    <a href="/Recipe/SaveRecipe/@Model.Id" class="btn @(ViewBag.IsSaved ? "btn-secondary text-white" : "btn-warning text-dark") fw-bold ms-3 hover-effect shadow-sm border">
                        ⭐ @(ViewBag.IsSaved ? "Đã lưu (Bấm để hủy)" : "Lưu món ăn này")
                    </a>
                }
            </div>
        </div>
    </div>
</div>