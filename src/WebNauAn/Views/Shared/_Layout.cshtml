<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebNauAn</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebNauAn.styles.css" asp-append-version="true" />
</head>
<body>
    <style>
        body {
        background-image: url('/images/bg_cooking.jpg');
        background-attachment: fixed;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        }

        .container {
        background-color: rgba(255, 255, 255, 0.95);
        border-radius: 10px;
        padding: 20px;
        box-shadow: 0px 4px 15px rgba(0,0,0,0.1);
        }

        /* KHU VỰC CSS TẠO HIỆU ỨNG HOVER */
        .hover-effect {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .hover-effect:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.2) !important;
        z-index: 10;
        cursor: pointer;
        }

        /* Hover cho thanh Menu */
        .nav-item .nav-link {
        transition: all 0.3s ease;
        }

        .nav-item .nav-link:hover {
        color: #28a745 !important;
        transform: scale(1.05);
        text-shadow: 0 0 5px rgba(40,167,69,0.3);
        }

        /* Hover cho danh mục bên trái */
        .list-group-item-action {
        transition: padding-left 0.3s ease, background-color 0.3s;
        }

        .list-group-item-action:hover {
        padding-left: 1.5rem !important;
        background-color: #f1f8f5;
        color: #198754;
        font-weight: bold;
        }

        /* Hover cho Top món ăn */
        .top-item-hover {
        transition: background-color 0.2s;
        }

        .top-item-hover:hover {
        background-color: #fcf8e3;
        }
    </style>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-success hover-effect" asp-area="" asp-controller="Recipe" asp-action="Index">🍽️ WebNauAn</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @using Microsoft.AspNetCore.Http
                    <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" href="/Recipe">🏠 Trang Chủ Món Ăn</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" href="/Recipe/Create">✍️ Đăng Công Thức</a>
                        </li>
                        @if (!string.IsNullOrEmpty(Context.Session.GetString("Username")))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-bold" href="/Recipe/SavedList">⭐ Kho Yêu Thích</a>
                            </li>
                        }
                        @if (Context.Session.GetString("Role") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-danger font-weight-bold" href="/Recipe/AdminDuyet">🛡️ Kênh Admin</a>
                            </li>
                        }
                        @if (string.IsNullOrEmpty(Context.Session.GetString("Username")))
                        {
                            <li class="nav-item ms-auto"><a class="nav-link text-primary fw-bold border rounded px-3 me-2 hover-effect" href="/Account/Register">Đăng Ký</a></li>
                            <li class="nav-item"><a class="nav-link text-white bg-success fw-bold border rounded px-3 hover-effect" href="/Account/Login">Đăng Nhập</a></li>
                        }
                        else
                        {
                            <li class="nav-item ms-auto"><span class="nav-link text-dark">👋 Chào, <b class="text-success">@Context.Session.GetString("Username")</b></span></li>
                            <li class="nav-item"><a class="nav-link text-danger fw-bold hover-effect" href="/Account/Logout">Đăng Xuất</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer mt-5" style="background-color: #fff8f3;">
        <div class="container py-3 text-center" style="color: #ff8a65;">
            🐷 © @DateTime.Now.Year WebNauAn • Công thức thì miễn phí, tăng cân thì tự chịu nha 😆
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>